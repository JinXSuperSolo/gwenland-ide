{
  "productName": "GwenLand IDE",
  "identifier": "land.gwen.ide",
  "version": "0.1.22",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "./ui/dist",
    "beforeDevCommand": "cd ../ui && pnpm dev",
    "beforeBuildCommand": "cd ../ui && pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "assetProtocol": {
        "enable": true
      }
    },
    "windows": [
      {
        "title": "GwenLand IDE",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "template": "src/installer.nsi"
      }
    }
  }
}
